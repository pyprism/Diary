# Environment configuration for Diary
# Auto-generated by Ansible — do not edit manually on the server

# Django Core Settings
secret_key='{{ django_secret_key }}'
debug={{ django_debug | lower }}
allowed_hosts={{ django_allowed_hosts | join(',') if django_allowed_hosts is iterable and django_allowed_hosts is not string else django_allowed_hosts }}

# Database Configuration
db_name={{ db_name }}
db_user={{ db_user }}
db_password={{ db_password }}
db_host={{ db_host }}
db_port={{ db_port }}

# Docker Compose Settings
server_port={{ server_port }}

# Sentry (optional)
{% if sentry_dsn is defined and sentry_dsn %}
sentry_dsn={{ sentry_dsn }}
{% else %}
sentry_dsn=
{% endif %}

# AWS S3 Configuration
aws_access_key_id={{ aws_access_key_id }}
aws_secret_access_key={{ aws_secret_access_key }}
aws_storage_bucket_name={{ aws_storage_bucket_name }}
aws_s3_region_name={{ aws_s3_region_name }}
aws_s3_custom_domain={{ aws_s3_custom_domain }}
aws_s3_endpoint_url={{ aws_s3_endpoint_url }}

# RabbitMQ (Celery broker)
rabbitmq_url={{ rabbitmq_url }}

# OpenRouter LLM
openrouter_api_key={{ openrouter_api_key }}
openrouter_model={{ openrouter_model }}
openrouter_timeout={{ openrouter_timeout }}

# etc
time_zone={{ time_zone }}
registration_open={{ registration_open | lower }}
share_link_expiry_seconds={{ share_link_expiry_seconds }}
