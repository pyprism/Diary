# Example secrets file - Copy to secrets.yml and fill in your values
# IMPORTANT: Add secrets.yml to .gitignore - NEVER commit secrets to git!

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
# Base directory where application will be deployed
deployment_base_dir: "/opt/Diary"

# Deployment user (will be created on server if doesn't exist)
deployment_user: "diary"

# =============================================================================
# GIT/SSH SETTINGS (for private repositories)
# =============================================================================
# OPTION 1: Deploy an SSH key to server (recommended for CI/CD)
# Generate a deploy key: ssh-keygen -t rsa -b 4096 -C "deploy@diary" -f deploy_key
# Add deploy_key.pub as a deploy key in GitHub repo settings
#git_ssh_private_key: ""
#git_ssh_public_key: ""

# OPTION 2: Use HTTPS with Personal Access Token
# Change project_repo in group_vars/all.yml to:
# project_repo: "https://{{ github_username }}:{{ github_token }}@github.com/pyprism/Diary.git"
# github_username: "your-github-username"
# github_token: "ghp_your_personal_access_token_here"

# =============================================================================
# DJANGO SETTINGS
# =============================================================================
django_secret_key: "randomly-generated"
django_debug: false
django_allowed_hosts: ["127.0.0.1", "localhost"]

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
db_name: hiren_diary
db_user: username
db_password: "password"
db_host: host-gateway  # use "localhost" if database is on the same server, or IP/hostname if remote
db_port: 5432

# =============================================================================
# DOCKER SETTINGS
# =============================================================================
# Port on the host that maps to container port 8000
server_port: 7342

# =============================================================================
# SENTRY (optional - leave empty if not using)
# =============================================================================
sentry_dsn: ""

#AWS S3 Configuration
aws_access_key_id:
aws_secret_access_key:
aws_storage_bucket_name: diary
aws_s3_region_name: us-east-1
aws_s3_custom_domain:
aws_s3_endpoint_url:

# RabbitMQ (Celery broker)
# Format: amqp://<user>:<password>@<host>:<port>/<vhost>
rabbitmq_url: "amqp://admin:password@host-gateway:5672/diary/"

# OpenRouter LLM
# Get your key at https://openrouter.ai/keys
openrouter_api_key: "secret-openrouter-api-key"
# Model name — change to any OpenRouter-compatible model
openrouter_model: "google/gemma-4-31b-it:free"
# Request timeout in seconds before Celery retries
openrouter_timeout: 120

# etc
registration_open: true
share_link_expiry_seconds: 86400
time_zone: "Asia/Dhaka"
